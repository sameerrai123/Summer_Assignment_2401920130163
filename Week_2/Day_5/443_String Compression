class Solution {
    public int compress(char[] chars) {
        int index = 0;  // for writing values
        int i = 0;    //for trvaersing chars

        while(i < chars.length){
            int count = 0;
            char curr = chars[i];

            while(i < chars.length && chars[i] == curr){
                count++;
                i++;
            }
            
            chars[index++] = curr;

            if(count > 1){
                String freq = String.valueOf(count);

                for(char ch : freq.toCharArray()){
                    chars[index++] = ch;
                }
            }
        }
        return index;
    }
}
