// jab bhi string me freq store karane type logic ho like anagram , count , freq , present hai bya nahi type and lower case only ho usme then
// use int [] frq = new int [26]  and tore freq[ch - 'a'] is for storing ch as intger index 


class Solution {
    public boolean canConstruct(String ransomNote, String magazine) {
        int[] freq = new int[26];

        for(int i = 0; i < magazine.length(); i++){
            freq[magazine.charAt(i) - 'a']++;
        }

        for(int j = 0; j < ransomNote.length(); j++){
            if(freq[ransomNote.charAt(j) - 'a'] == 0){
                return false;
            }

            freq[ransomNote.charAt(j) - 'a']--;
        }

        return true;
    }
}
